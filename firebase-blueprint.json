{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users with specific roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "RSM", "STATE_MANAGER", "ASM", "DEALER", "CLINIC"] },
        "dealerId": { "type": "string", "description": "Pointer to the Dealer Account in /accounts collection" },
        "dealerCode": { "type": "string", "description": "The unique code for this dealer account" },
        "territory": { "type": "string", "description": "Assigned Territory Code (e.g., UP01) for ASMs" },
        "stateCode": { "type": "string", "description": "Assigned State Code (e.g., UP, DL) for State Managers" },
        "region": { "type": "string", "description": "Assigned Region Code (NORTH, SOUTH, EAST, WEST) for RSMs" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Account": {
      "title": "Account",
      "description": "Dental Clinics or Dental Partners/Dealers.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["CLINIC", "DEALER"] },
        "address": { "type": "string" },
        "region": { "type": "string" },
        "stateCode": { "type": "string" },
        "territory": { "type": "string" },
        "dealerCode": { "type": "string" },
        "resellerLandingCost": { "type": "number" },
        "noOfPatients": { "type": "number" },
        "clinicType": { "type": "string" },
        "visitCounter": { "type": "number", "default": 0 },
        "firstConvertedVisit": { "type": "boolean", "default": false },
        "slab": { "type": "string" }
      },
      "required": ["name", "type"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Doctors or Dentists associated with a Clinic.",
      "type": "object",
      "properties": {
        "accountId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "specialty": { "type": "string" },
        "mobile": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["accountId", "firstName", "lastName"]
    },
    "Product": {
      "title": "Product",
      "description": "Master product catalog.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "code": { "type": "string" },
        "division": { "type": "string" },
        "brand": { "type": "string" },
        "active": { "type": "boolean" },
        "category": { "type": "string" },
        "packSize": { "type": "string" },
        "standardPrice": { "type": "number" },
        "resellerPrice": { "type": "number" },
        "dentistPrice": { "type": "number" }
      },
      "required": ["name", "code"]
    },
    "Visit": {
      "title": "Visit",
      "description": "Main transaction record for dealer clinic visits.",
      "type": "object",
      "properties": {
        "accountId": { "type": "string" },
        "dealerId": { "type": "string" },
        "dealerUid": { "type": "string" },
        "territory": { "type": "string" },
        "stateCode": { "type": "string" },
        "region": { "type": "string" },
        "contactId": { "type": "string" },
        "visitType": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "visitSubject": { "type": "string" },
        "currency": { "type": "string", "default": "INR" },
        "noOfPatients": { "type": "number" },
        "dateCount": { "type": "boolean", "default": false },
        "package": { "type": "string" },
        "testFinancialYear": { "type": "string" },
        "resellerLandingCost": { "type": "number" },
        "firstConvertedVisit": { "type": "boolean", "default": false },
        "digitalExponent2021": { "type": "string" },
        "rebrandyUrlDealer": { "type": "string", "format": "uri" },
        "rebrandyUrlDentist": { "type": "string", "format": "uri" },
        "dentistResponseUrl": { "type": "string", "format": "uri" },
        "urlVisitDetails": { "type": "string", "format": "uri" },
        "urlResponseFromClinic": { "type": "string", "format": "uri" },
        "urlResponseFromDealer": { "type": "string", "format": "uri" },
        "totalRevenue": { "type": "number", "default": 0 },
        "totalProductSold": { "type": "number", "default": 0 },
        "visitConverted": { "type": "boolean", "default": false }
      },
      "required": ["accountId", "dealerId", "dealerUid", "visitType", "dateTime"]
    },
    "SoldProduct": {
      "title": "SoldProduct",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "listPrice": { "type": "number" },
        "resellerCost": { "type": "number" },
        "totalSoldPrice": { "type": "number" },
        "totalListPrice": { "type": "number" }
      }
    },
    "DemoProduct": {
      "title": "DemoProduct",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "quantity": { "type": "number" },
        "remarks": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/accounts/{accountId}": { "schema": "Account", "description": "Clinics and Dealers" },
    "/accounts/{accountId}/contacts/{contactId}": { "schema": "Contact", "description": "Doctors at Clinics" },
    "/products/{productId}": { "schema": "Product", "description": "Product catalog" },
    "/visits/{visitId}": { "schema": "Visit", "description": "Visit logs" },
    "/visits/{visitId}/soldProducts/{soldId}": { "schema": "SoldProduct", "description": "Sold items" },
    "/visits/{visitId}/demoProducts/{demoId}": { "schema": "DemoProduct", "description": "Demoed items" },
    "/visits/{visitId}/freeProducts/{freeId}": { "schema": "DemoProduct", "description": "Free/Sample items" }
  }
}
